# 复制到项目根目录: cp deploy/docker/.env.example .env

# Master 对外端口
MASTER_PORT=8088

LOG_LEVEL=INFO

# 华为云 DNS (可选, 与 config.yaml 中 ${HUAWEICLOUD_AK} 等占位符对应)
HUAWEICLOUD_AK=
HUAWEICLOUD_SK=
HUAWEICLOUD_ZONE_ID=

# Agent 连接 Master (同一 compose 网络内用服务名; 远程 VPS 填公网 URL)
AGENT_MASTER_URL=http://master:8088

AGENT_CT_ISP=电信
AGENT_CT_NODE_NAME=ct-docker-01

AGENT_CU_ISP=联通
AGENT_CU_NODE_NAME=cu-docker-01

AGENT_CM_ISP=移动
AGENT_CM_NODE_NAME=cm-docker-01
