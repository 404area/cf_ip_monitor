# 复制到项目根: cp deploy/docker/.env.example .env

# ============================================================
# Master 公共
# ============================================================
# 对宿主机暴露的端口 (有 nginx 时一般不直接暴露, 仅作为内部端口)
MASTER_PORT=8088

LOG_LEVEL=INFO

# Agent 拉任务/回报使用的 Bearer Token, 任意长随机字符串, master 与 agent 必须一致
# config.yaml 里的 ${MASTER_AUTH_TOKEN} 与 ${AGENT_AUTH_TOKEN} 都会从这里读
# 同机 compose 场景: 只填这一个就够了 (agent 会自动 fallback)
MASTER_AUTH_TOKEN=change-me-to-a-long-random-token

# ============================================================
# 华为云 DNS (可选, master 端使用)
# config.yaml 里的 ${HUAWEICLOUD_AK} 等占位符对应这里
# ============================================================
HUAWEICLOUD_AK=
HUAWEICLOUD_SK=
HUAWEICLOUD_ZONE_ID=

# ============================================================
# Agent (同机 docker compose 用)
#
# AGENT_MASTER_URL 默认 http://master:8088 (compose 服务名), 通常不用改
# 如果 master 与 agent 不在同一 compose, 改成可达 URL, 比如:
#   http://192.168.1.10:8088   (内网)
#   https://master.example.com (公网 + nginx)
# ============================================================
AGENT_MASTER_URL=http://master:8088

# 留空时, agent 会自动 fallback 到 MASTER_AUTH_TOKEN
AGENT_AUTH_TOKEN=

# 三网 Agent 的 ISP 标签 + 节点名 (compose --profile agents 用)
AGENT_CT_ISP=电信
AGENT_CT_NODE_NAME=ct-docker-01
AGENT_CU_ISP=联通
AGENT_CU_NODE_NAME=cu-docker-01
AGENT_CM_ISP=移动
AGENT_CM_NODE_NAME=cm-docker-01

# ============================================================
# 远程单 Agent (docker-compose.agent.yml 用, 部署在 VPS 上)
#
# 三个变量都是必填, compose 会用 :? 语法在缺失时报错。
# ============================================================
# AGENT_MASTER_URL=https://master.example.com    # 公网 master URL
# AGENT_AUTH_TOKEN=...                           # 与 MASTER_AUTH_TOKEN 一致
# AGENT_ISP=电信
# AGENT_NODE_NAME=ct-vps-hk-01

# ============================================================
# nginx 反代 (compose --profile edge 启用)
# ============================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# 仅给文档/脚本提示用, nginx 实际域名在 deploy/nginx/master.conf 里的 server_name
MASTER_DOMAIN=master.example.com
